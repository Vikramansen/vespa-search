schema product {

    document product {

        field title type string {
            indexing: index | summary
            index: enable-bm25
        }

        field description type string {
            indexing: index | summary
            index: enable-bm25
        }

        field category type string {
            indexing: attribute | summary
            attribute: fast-search
        }

        field brand type string {
            indexing: attribute | summary
            attribute: fast-search
        }

        field price type double {
            indexing: attribute | summary
            attribute: fast-search
        }

        field rating type double {
            indexing: attribute | summary
        }

        field in_stock type bool {
            indexing: attribute | summary
        }

        field image_url type string {
            indexing: summary
        }
    }

    fieldset default {
        fields: title, description
    }

    rank-profile default {
        first-phase {
            expression: bm25(title) * 2 + bm25(description)
        }
    }

    rank-profile price_asc {
        first-phase {
            expression: -attribute(price)
        }
    }

    rank-profile price_desc {
        first-phase {
            expression: attribute(price)
        }
    }

    rank-profile top_rated {
        first-phase {
            expression: attribute(rating)
        }
    }
}
